#!/usr/bin/env node
import { constants, existsSync, lstatSync, readFileSync } from "node:fs";
import { access, readlink } from "node:fs/promises";
import { dirname, join, resolve } from "node:path";
import { fileURLToPath } from "node:url";
import { spawnSync } from "node:child_process";

const root = process.env.HOME
  ? join(process.env.HOME, "bin")
  : dirname(fileURLToPath(import.meta.url));
const registry =
  process.env.CC_MODELS_REGISTRY ?? join(root, "cc-model-registry.tsv");
const researchFile =
  process.env.CC_MODELS_RESEARCH ?? join(root, "cc-model-research.tsv");
const backlogFile =
  process.env.CC_MODELS_BACKLOG ?? join(root, "cc-model-backlog.md");
const fallbackCommands = [
  "cc-kimi",
  "cc-glm",
  "cc-qwen",
  "cc-deepseek",
  "cc-doubao",
  "cc-minimax",
  "cc-mimo",
  "cc-stepfun",
  "cc-longcat",
  "cc-gemini",
  "cc-grok",
  "cc-local",
];

const hasExecutable = async (path) => {
  try {
    await access(path, constants.X_OK);
    return true;
  } catch {
    return false;
  }
};

const loadRows = (file) => {
  if (!existsSync(file)) return [];
  return readFileSync(file, "utf8")
    .split(/\r?\n/u)
    .map((line) => line.split("\t"))
    .filter((cols) => {
      const first = cols[0]?.trim() ?? "";
      return first.length > 0 && !first.startsWith("#");
    });
};

const loadCommands = () => {
  const rows = loadRows(registry);
  if (rows.length === 0) return fallbackCommands;
  return rows
    .map((cols) => cols[0])
    .filter((cmd) => cmd !== undefined && cmd.length > 0);
};

const commands = loadCommands();
const print = (message = "") => console.log(message);
const warn = (message) => console.error(`[cc-models] ${message}`);
const normalizeCmd = (value = "") =>
  value.length === 0 || value.startsWith("cc-") ? value : `cc-${value}`;

const scriptPathFor = async (cmd) => {
  const path = join(root, cmd);
  if (existsSync(path) && lstatSync(path).isSymbolicLink()) {
    const target = await readlink(path);
    return target.startsWith("/") ? target : join(root, target);
  }
  return path;
};

const targetFor = async (cmd) => {
  const path = join(root, cmd);
  if (existsSync(path) && lstatSync(path).isSymbolicLink())
    return await readlink(path);
  if (existsSync(path)) return path;
  return "missing";
};

const usage = () => {
  console.error(`Usage: cc-models <command>

Commands:
  list      Show high-frequency cc-* launchers and configured models
  matrix    Show configured tier mapping and routes
  sources   Show primary official/reference source per launcher
  research  Show research/source-status table
  backlog   Show continuation backlog
  doctor    Run --doctor for all launchers, or one: cc-models doctor qwen
  env       Print non-secret env for one launcher: cc-models env deepseek
  profiles  Show provider-specific profile knobs
  audit     Run syntax checks for installed launchers, list, and doctor
  paths     Show launcher paths`);
};

const pad = (value, width) => value.padEnd(width, " ");

const listModels = async () => {
  for (const cmd of commands) {
    const path = join(root, cmd);
    if (!(await hasExecutable(path))) {
      print(`${pad(cmd, 12)} missing`);
      continue;
    }
    const result = spawnSync(path, ["--list"], { encoding: "utf8" });
    const raw = result.status === 0 ? result.stdout : "unavailable";
    const models = raw
      .split(/\r?\n/u)
      .filter((line) => line.length > 0)
      .join(", ");
    print(`${pad(cmd, 12)} ${models}`);
  }
};

const doctorAll = async (only = "") => {
  const normalized = normalizeCmd(only);
  for (const cmd of commands) {
    if (normalized.length > 0 && cmd !== normalized) continue;
    const path = join(root, cmd);
    if (!(await hasExecutable(path))) {
      print(`${cmd}: missing`);
      continue;
    }
    const result = spawnSync(path, ["--doctor"], { stdio: "inherit" });
    if (result.status !== 0) print(`${cmd}: doctor failed`);
    print();
  }
};

const envOne = async (value = "") => {
  const cmd = normalizeCmd(value);
  if (cmd.length === 0) {
    warn("env requires a launcher name, e.g. qwen");
    process.exit(2);
  }
  const path = join(root, cmd);
  if (!(await hasExecutable(path))) {
    warn(`launcher not found: ${cmd}`);
    process.exit(127);
  }
  const result = spawnSync(path, ["--env"], { stdio: "inherit" });
  process.exit(result.status ?? 1);
};

const paths = async () => {
  for (const cmd of commands) {
    print(`${pad(cmd, 12)} ${join(root, cmd)} -> ${await targetFor(cmd)}`);
  }
};

const matrix = () => {
  if (!existsSync(registry)) {
    warn(`registry missing: ${registry}`);
    process.exit(1);
  }
  print(
    `${pad("command", 12)} ${pad("provider", 10)} ${pad("route", 22)} ${pad("default", 28)} ${pad("opus", 28)} ${pad("sonnet", 28)} ${pad("haiku", 24)}`,
  );
  for (const cols of loadRows(registry)) {
    if (cols.length < 8) continue;
    print(
      `${pad(cols[0] ?? "", 12)} ${pad(cols[1] ?? "", 10)} ${pad(cols[2] ?? "", 22)} ${pad(cols[3] ?? "", 28)} ${pad(cols[4] ?? "", 28)} ${pad(cols[5] ?? "", 28)} ${pad(cols[6] ?? "", 24)}`,
    );
  }
};

const sources = () => {
  if (!existsSync(registry)) {
    warn(`registry missing: ${registry}`);
    process.exit(1);
  }
  for (const cols of loadRows(registry)) {
    if (cols.length < 9) continue;
    print(`${pad(cols[0] ?? "", 12)} ${cols[8] ?? ""}`);
  }
};

const research = () => {
  if (!existsSync(researchFile)) {
    warn(`research file missing: ${researchFile}`);
    process.exit(1);
  }
  print(
    `${pad("command", 12)} ${pad("grade", 6)} ${pad("status", 18)} ${pad("official_doc", 54)} next_action`,
  );
  for (const cols of loadRows(researchFile)) {
    if (cols.length < 6) continue;
    print(
      `${pad(cols[0] ?? "", 12)} ${pad(cols[3] ?? "", 6)} ${pad(cols[4] ?? "", 18)} ${pad(cols[1] ?? "", 54)} ${cols[5] ?? ""}`,
    );
  }
};

const profiles = () => {
  print(`command      env var            profiles
cc-kimi      KIMI_*             kimi-for-coding route; KIMI_NO_CACHE=1 opt-out of prompt cache
cc-glm       GLM_PROFILE        balanced, max/opus, turbo, cheap/lite; GLM_THINKING=auto|enabled|disabled
cc-qwen      QWEN_PROFILE       coder, coding-plan/plan, token/token-plan, max/payg/intl, cheap/flash
cc-deepseek  DEEPSEEK_PROFILE   agent/pro, flash/cheap, instant
cc-doubao    DOUBAO_PROFILE     latest, agent, vision/frontend, pinned, router, seed20/reasoning, cheap
cc-minimax   MINIMAX_PROFILE    stable/token, highspeed/payg, cheap/lite; MINIMAX_REGION=cn|global
cc-mimo      MIMO_PROFILE       pro, latest/v25, multimodal/omni, fast/flash; MIMO_REGION=sgp|public|cn|ams
cc-stepfun   STEPFUN_PROFILE    reasoning, fast/flash, router; STEPFUN_REASONING=low|high|none
cc-longcat   LONGCAT_PROFILE    agent, fast/lite, stable/chat, thinking; Preview capped at 64K`);
};

const backlog = () => {
  if (!existsSync(backlogFile)) {
    warn(`backlog file missing: ${backlogFile}`);
    process.exit(1);
  }
  print(
    readFileSync(backlogFile, "utf8").split(/\r?\n/u).slice(0, 260).join("\n"),
  );
};

const audit = async () => {
  let failed = false;
  print("[cc-models] syntax");
  const nodeCheck = spawnSync(
    process.execPath,
    ["--check", fileURLToPath(import.meta.url)],
    {
      stdio: "inherit",
    },
  );
  if (nodeCheck.status !== 0) failed = true;

  const libCheck = spawnSync("bash", ["-n", join(root, "cc-model-lib.sh")], {
    stdio: "inherit",
  });
  if (libCheck.status !== 0) failed = true;

  for (const cmd of commands) {
    const script = await scriptPathFor(cmd);
    if (existsSync(script)) {
      const result = spawnSync("bash", ["-n", script], { stdio: "inherit" });
      if (result.status !== 0) failed = true;
    } else if (process.env.CC_MODELS_AUDIT_REQUIRE_ALL === "1") {
      warn(`missing script for ${cmd}: ${script}`);
      failed = true;
    } else {
      warn(`skip missing optional launcher ${cmd}: ${script}`);
    }
  }

  print();
  print("[cc-models] list");
  await listModels();
  print();
  print("[cc-models] doctor");
  await doctorAll();
  process.exit(failed ? 1 : 0);
};

const [command = "", arg = ""] = process.argv.slice(2);

switch (command) {
  case "list":
    await listModels();
    break;
  case "matrix":
    matrix();
    break;
  case "sources":
    sources();
    break;
  case "research":
    research();
    break;
  case "backlog":
    backlog();
    break;
  case "doctor":
    await doctorAll(arg);
    break;
  case "env":
    await envOne(arg);
    break;
  case "profiles":
    profiles();
    break;
  case "audit":
    await audit();
    break;
  case "paths":
    await paths();
    break;
  case "":
  case "-h":
  case "--help":
  case "help":
    usage();
    break;
  default:
    warn(`unknown command: ${command}`);
    usage();
    process.exit(2);
}
