#!/usr/bin/env bash
# fanout — fan-out workflow unified entrypoint (aggregates each tool, one command face)
#
#   fanout doctor              env recon + workflow recommendation
#   fanout fleet status|up [--pty]|down  bring up/view/stop ccb fleet (strip CLAUDE_CODE_* + detached tmux; --pty=pty.fork fallback)
#   fanout preflight [cfg]     pre-run go/no-go gate (deps/ccbd/no-Gemini/config)
#   fanout task new|log|done   TASK file scaffold/log/finalize
#   fanout template <n> [--set K=V]   render prompt template (impl|analysis|review)
#   fanout dispatch <agent> --template <n>|--prompt-file <f> [--task <file>]
#                              wraps ccb ask: render prompt → dispatch → log
#   fanout cache ...           result cache + fan-in barrier (init|put|fail|barrier|collect|resume|...)
#   fanout integrate --work <repo> --agents "a b" [--onconflict abort|skip]  Phase3 worktree→main cherry-pick(conflict isolation)
#   fanout allocate <task-type> [--top]|record|stats|reset   recommend model (bench prior + live posterior mix)
#   fanout skills index|list|match|show|inject   local skills catalog(mother dir)+ inject agent on demand
#   fanout workspace list|show|model|context <name>   workspace context isolation (Zleap-inspired)
#   fanout experience add|list|recall|show <ws>   experience memory: done→extract method→redact store→reuse
#   fanout plan "<goal>" [--models a,b,c]   multi-model planning panel (each Writes a plan)
#   fanout goal template|show|check <spec>  goal mode: declarative goal + deterministic acceptance gate
#   fanout loop init|record|decide|status   Phase 5 review-fix state machine (exit-state decision+keep-best)
#   fanout run set|round|status|next|clear   cross-phase run status facade (aggregate TASK/cache/loop → JSON, axi-inspired)
#   fanout summary <round> [--task <file>]   round observability summary (incl. elapsed)
#   fanout ccb-sync check|adapt [--apply]    post-ccb-update sync adapt (version/grafting/ccbd restart)
#   fanout selftest            run all *.test.sh
#   fanout help                this help
set -uo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLI_NAME="${FUGUE_DRIVER_NAME:-fanout}"
print_help(){ sed -n '2,24p' "$0" | sed -E "s/^# fanout/# $CLI_NAME/; s/^#   fanout /#   $CLI_NAME /"; }

sub="${1:-help}"; shift || true
case "$sub" in
  doctor)    exec bash "$HERE/fanout-doctor.sh"    "$@";;
  preflight) exec bash "$HERE/fanout-preflight.sh" "$@";;
  fleet)     exec bash "$HERE/fanout-fleet.sh"     "$@";;
  task)      exec bash "$HERE/fanout-task.sh"      "$@";;
  template)  exec bash "$HERE/fanout-template.sh"  "$@";;
  dispatch)  exec bash "$HERE/fanout-dispatch.sh"  "$@";;
  cache)     exec bash "$HERE/fanout-cache.sh"     "$@";;
  integrate) exec bash "$HERE/fanout-integrate.sh" "$@";;
  allocate)  exec bash "$HERE/fanout-allocate.sh"  "$@";;
  skills)    exec bash "$HERE/fanout-skills.sh"    "$@";;
  workspace) exec bash "$HERE/fanout-workspace.sh" "$@";;
  experience) exec bash "$HERE/fanout-experience.sh" "$@";;
  plan)      exec bash "$HERE/fanout-plan.sh"      "$@";;
  goal)      exec bash "$HERE/fanout-goal.sh"      "$@";;
  loop)      exec bash "$HERE/fanout-loop.sh"      "$@";;
  run)       exec bash "$HERE/fanout-run.sh"       "$@";;
  summary|round-summary) exec bash "$HERE/fanout-summary.sh" "$@";;
  ccb-sync)  exec bash "$HERE/fanout-ccb-sync.sh" "$@";;
  selftest)
    ec=0
    for t in "$HERE"/*.test.sh; do
      [ -f "$t" ] || continue
      echo "── $(basename "$t") ──"
      ( unset FUGUE_DRIVER_NAME; bash "$t" ) || ec=1
    done
    [ "$ec" -eq 0 ] && echo "✓ selftest all passed" || echo "✗ selftest had failures"
    exit "$ec";;
  help|-h|--help) print_help;;
  *) echo "$CLI_NAME: unknown subcommand '$sub' (doctor|fleet|preflight|task|template|dispatch|cache|integrate|allocate|skills|workspace|experience|plan|goal|loop|run|summary|ccb-sync|selftest|help)" >&2; exit 2;;
esac
