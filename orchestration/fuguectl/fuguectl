#!/usr/bin/env node
import { existsSync, readdirSync } from "node:fs";
import { basename, dirname, join } from "node:path";
import { fileURLToPath } from "node:url";
import { spawnSync } from "node:child_process";
import { runEngine } from "./fuguectl-node-bridge.mjs";

const here = dirname(fileURLToPath(import.meta.url));

const help = `fuguectl — fugue workflow control-plane entrypoint.

  fuguectl doctor              env recon + workflow recommendation
  fuguectl init [--dry-run|--write]  first-run readiness + local scaffold hints
  fuguectl version             print engine version
  fuguectl fleet status|up [--pty]|down  bring up/view/stop fugue-cc fleet
  fuguectl preflight [--harness fugue-cc|codex|opencode|agy|lite|all] [--model m|--target m] [cfg]  pre-run go/no-go gate
  fuguectl smoke [--harness all|codex|opencode|agy] [--timeout-ms n] [--task <file>] [--out-dir <dir>]  live lite-runtime smoke (+ <out-dir>/summary.json)
  fuguectl task new|log|done|handoff|digest   TASK file scaffold/log/finalize/handoff/digest packet
  fuguectl guard prompt <file|-> [--json] [--source-ref ref]  pre-dispatch runtime guard packet
  fuguectl review packet <file|-> [--json]  parse reviewer output into a structured review-fix packet
  fuguectl incident packet|recovery <file|-> [--json] [--source-ref ref]  parse failure logs into incident/recovery packets
  fuguectl template <n> [--set K=V]   render prompt template
  fuguectl dispatch <agent> [--harness fugue-cc|codex|opencode|agy] [--timeout-ms n] [--codex-clean] [--harness-arg x] [--out <file>] [--certificate <file> [--approval-class class] [--certificate-assumption text] [--certificate-externality fact]] [--require-output] [--verbose] [--workspace ws [--experience-query q] [--experience-source manual|task] [--experience-source-ref ref] [--experience-limit n] [--experience-budget-chars n] [--experience-trust trusted|all] [--experience-max-age-days n]] --template <n>|--prompt-file <f>|--prompt <text> [--task <file>]
  fuguectl cache ...           result cache + join barrier
  fuguectl integrate --work <repo> --agents "a b" [--onconflict abort|skip]
  fuguectl allocate <task-type> [--top]|record|stats|reset
  fuguectl skills index|list|match|show|inject|validate|forge
  fuguectl workspace list|show|model|context <name> [context: --experience-source manual|task --experience-source-ref ref --experience-limit n --experience-budget-chars n --experience-trust trusted|all --experience-max-age-days n]
  fuguectl agents template|validate [file]|list [file]|resolve [file] <id>
  fuguectl experience add|audit|eval|learn|list|policy|promote|recall|show <ws> [add: --trust trusted|untrusted --source-ref ref --supersedes slug] [audit: --json --max-age-days n] [eval: --cases file --json] [learn: --supersedes slug] [policy: <slug>|--query q --json] [promote: <slug> --source-ref ref --confirm-source-ref ref] [recall: --query q --source manual|task --source-ref ref --trust trusted|untrusted|all --min-score n --max-age-days n --include-superseded --explain --json --metadata-only]
  fuguectl plan "<goal>" [--harness fugue-cc|codex|opencode|agy|lite] [--models a,b,c] [--out <dir>] [--timeout-ms n] [--allow-partial] [--codex-clean] [--harness-arg x] [--codex-arg x] [--opencode-arg x] [--agy-arg x] [--task <file>]  writes <out>/summary.json
  fuguectl goal template|show|check <spec>
  fuguectl loop init|record|decide|status
  fuguectl run set|round|status|next|clear
  fuguectl summary <round> [--task <file>]
  fuguectl self-harness template|run  harness self-improvement loop
  fuguectl runtime check [--strict]|adapt [--apply] [--skill <installed SKILL.md>] [--alias-skill <legacy SKILL.md>] [--repo-skill <repo SKILL.md>]
  fuguectl selftest            run all *.test.mjs
  fuguectl help [quickstart]   this help`;

const quickstartHelp = `fuguectl quickstart — safe first run

  1. Inspect your machine:
     fuguectl doctor
     fuguectl init --dry-run

  2. Verify available lightweight runtimes:
     fuguectl preflight --harness lite
     fuguectl smoke --harness all --codex-clean --timeout-ms 120000 --out-dir /tmp/fugunano-smoke

  3. Create durable planning artifacts:
     fuguectl plan "your goal" --harness lite --codex-clean --timeout-ms 120000 --allow-partial --out /tmp/fugunano-plan --task TASK.md

  4. Optional full fleet setup:
     fuguectl init --write
     fuguectl preflight --harness fugue-cc

No command above writes project code. Only 'fuguectl init --write' creates local config templates.`;

const selftest = () => {
  let failed = false;
  for (const file of readdirSync(here).sort()) {
    if (!file.endsWith(".test.mjs")) continue;
    const test = join(here, file);
    if (!existsSync(test)) continue;
    console.log(`── ${basename(test)} ──`);
    const result = spawnSync(process.execPath, [test], { stdio: "inherit" });
    if (result.status !== 0) failed = true;
  }
  console.log(failed ? "✗ selftest had failures" : "✓ selftest all passed");
  process.exit(failed ? 1 : 0);
};

const args = process.argv.slice(2);
const [subcommand = "help", ...rest] = args;
const commandMap = new Map([
  ["doctor", "doctor"],
  ["init", "init"],
  ["version", "version"],
  ["preflight", "preflight"],
  ["smoke", "smoke"],
  ["fleet", "fleet"],
  ["task", "task"],
  ["guard", "guard"],
  ["review", "review"],
  ["incident", "incident"],
  ["template", "template"],
  ["dispatch", "dispatch"],
  ["cache", "cache"],
  ["integrate", "integrate"],
  ["allocate", "allocate"],
  ["skills", "skills"],
  ["workspace", "workspace"],
  ["agents", "agent-registry"],
  ["experience", "experience"],
  ["plan", "plan"],
  ["goal", "goal"],
  ["loop", "loop"],
  ["run", "run"],
  ["summary", "summary"],
  ["round-summary", "summary"],
  ["self-harness", "self-harness"],
  ["runtime", "runtime"],
]);

if (subcommand === "help" || subcommand === "-h" || subcommand === "--help") {
  const [topic = ""] = rest;
  if (topic === "" || topic === "help") console.log(help);
  else if (topic === "quickstart") console.log(quickstartHelp);
  else {
    console.error(
      `fuguectl: unknown help topic '${topic}' (try: fuguectl help quickstart)`,
    );
    process.exit(2);
  }
} else if (subcommand === "selftest") {
  selftest();
} else if (commandMap.has(subcommand)) {
  runEngine([commandMap.get(subcommand), ...rest]);
} else {
  console.error(
    `fuguectl: unknown subcommand '${subcommand}' (doctor|init|version|fleet|preflight|smoke|task|guard|review|incident|template|dispatch|cache|integrate|allocate|skills|workspace|agents|experience|plan|goal|loop|run|summary|self-harness|runtime|selftest|help)`,
  );
  console.error("try: fuguectl help or fuguectl help quickstart");
  process.exit(2);
}
