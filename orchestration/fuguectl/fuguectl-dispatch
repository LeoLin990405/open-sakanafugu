#!/usr/bin/env node
import { runSimpleBridge } from "./fuguectl-node-bridge.mjs";

runSimpleBridge({
  argv: process.argv.slice(2),
  command: "dispatch",
  helpOnEmpty: false,
  help: `fuguectl-dispatch <target> [--harness fugue-cc|codex|opencode] [--timeout-ms n] [--harness-arg x] [--workspace <ws>] (--template <name> [--set K=V ...] | --prompt-file <f> | --prompt <text>) [--task <file>]
--task-type T  append (T, agent) into alloc ledger
--skills a,b   inject selected skills into that agent context
`,
});
