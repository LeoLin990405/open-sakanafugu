#!/usr/bin/env node
import { runSubcommandBridge } from "./fuguectl-node-bridge.mjs";

runSubcommandBridge({
  argv: process.argv.slice(2),
  command: "runtime",
  allowed: ["check", "adapt"],
  help: `fuguectl-runtime — TypeScript runtime sync bridge

check [--strict] print current/last provider version + workflow bundle drift; --strict exits non-zero on bundle drift
adapt [--apply]  verify grafting, sync workflow bundle, optionally restart daemon, preflight, record version

Options: --strict --skill <installed SKILL.md> --alias-skill <legacy SKILL.md> --repo-skill <repo SKILL.md>
`,
  unknown: (subcommand) =>
    `fuguectl-runtime: unknown subcommand '${subcommand}' (check|adapt)`,
});
