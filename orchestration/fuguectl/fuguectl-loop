#!/usr/bin/env node
import { runSimpleBridge } from "./fuguectl-node-bridge.mjs";

runSimpleBridge({
  argv: process.argv.slice(2),
  command: "loop",
  help: `fuguectl-loop — TypeScript review-fix loop bridge

init  [--max N] [--task F] [--best-sha SHA] [--best-n N]
record <round> --gate pass|fail --verdict ACCEPTED|NEEDSFIX --findings N [--ask-user K] [--sha SHA] [--same-class] [--note "..."]
       (or --review <file> to derive --verdict + --findings from a review packet; explicit flags override)
decide|next
status
`,
});
